<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- BLOCK: Titanium Gradient -->
    <!-- PURPOSE: Replicates anodized titanium rainbow effect for buttons -->
    <!-- SAFE: comment only -->
    <gradient
        android:type="linear"
        android:startColor="#7B2CBF"
        android:centerColor="#4A8FE7"
        android:endColor="#3DDC84"
        android:angle="45" />

    <!-- BLOCK: Titanium Edge Stroke -->
    <!-- PURPOSE: Gold accent stroke for metallic highlight -->
    <!-- SAFE: comment only -->
    <stroke
        android:width="2dp"
        android:color="#FFD700" />

    <!-- BLOCK: Corner Radius -->
    <!-- PURPOSE: Smooth rounded edges for titanium theme consistency -->
    <!-- SAFE: comment only -->
    <corners android:radius="8dp" />

    <!-- BLOCK: Padding -->
    <!-- PURPOSE: Ensures proper spacing inside button background -->
    <!-- SAFE: comment only -->
    <padding
        android:left="4dp"
        android:top="4dp"
        android:right="4dp"
        android:bottom="4dp" />

</shape>

