<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- BLOCK: Titanium Sweep Gradient -->
    <!-- PURPOSE: Creates circular anodized titanium rainbow ring -->
    <!-- SAFE: comment only -->
    <gradient
        android:type="sweep"
        android:startColor="#7B2CBF"
        android:centerColor="#4A8FE7"
        android:endColor="#3DDC84" />

    <!-- BLOCK: Titanium Gold Stroke -->
    <!-- PURPOSE: Gold metallic outer ring highlight -->
    <!-- SAFE: comment only -->
    <stroke
        android:width="3dp"
        android:color="#FFD700" />

    <!-- BLOCK: Circular Radius -->
    <!-- PURPOSE: Forces perfect circle for avatar ring -->
    <!-- SAFE: comment only -->
    <corners android:radius="999dp" />

</shape>

