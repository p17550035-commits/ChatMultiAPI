<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- BLOCK: Selected Bubble Background -->
    <!-- PURPOSE: Purple highlight for selected chat bubble -->
    <!-- SAFE: comment only -->
    <item android:state_selected="true">
        <shape>
            <solid android:color="#7B2CBF" />
            <corners android:radius="16dp" />
        </shape>
    </item>

    <!-- BLOCK: Default Bubble Background -->
    <!-- PURPOSE: Standard dark bubble background -->
    <!-- SAFE: comment only -->
    <item>
        <shape>
            <solid android:color="#1E1E1E" />
            <corners android:radius="16dp" />
        </shape>
    </item>

</selector>

