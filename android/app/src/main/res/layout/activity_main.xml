<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- BLOCK: Face Avatar -->
    <!-- PURPOSE: Displays avatar with titanium ring -->
    <!-- SAFE: comment only -->
    <ImageView
        android:id="@+id/faceAvatar"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_margin="12dp"
        android:src="@mipmap/ic_launcher"
        android:scaleType="centerCrop"
        android:background="@drawable/titanium_ring"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- BLOCK: Titanium Top Bar -->
    <!-- PURPOSE: Chat, Projects, Terminal, API, Security, Settings tabs -->
    <!-- SAFE: comment only -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="12dp"
        android:orientation="horizontal"
        android:gravity="end"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/faceAvatar"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- BLOCK: Chat Tab -->
        <!-- PURPOSE: Returns to main chat screen -->
        <!-- SAFE: comment only -->
        <ImageButton
            android:id="@+id/btnChat"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/titanium_button"
            android:src="@android:drawable/ic_menu_view"
            android:tint="#FFFFFF"
            android:contentDescription="Chat" />

        <!-- BLOCK: Projects Tab -->
        <!-- PURPOSE: Opens ProjectsActivity -->
        <!-- SAFE: comment only -->
        <ImageButton
            android:id="@+id/btnProjects"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/titanium_button"
            android:src="@android:drawable/ic_menu_agenda"
            android:tint="#FFFFFF"
            android:contentDescription="Projects" />

        <!-- BLOCK: Terminal Tab -->
        <!-- PURPOSE: Placeholder for full terminal module -->
        <!-- SAFE: comment only -->
        <ImageButton
            android:id="@+id/btnTerminal"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/titanium_button"
            android:src="@android:drawable/ic_menu_manage"
            android:tint="#FFFFFF"
            android:contentDescription="Terminal" />

        <!-- BLOCK: API Tab -->
        <!-- PURPOSE: Opens API keys manager -->
        <!-- SAFE: comment only -->
        <ImageButton
            android:id="@+id/btnAPI"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/titanium_button"
            android:src="@android:drawable/ic_menu_info_details"
            android:tint="#FFFFFF"
            android:contentDescription="API" />

        <!-- BLOCK: Security Tab -->
        <!-- PURPOSE: Opens SecurityActivity -->
        <!-- SAFE: comment only -->
        <ImageButton
            android:id="@+id/btnSecurity"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/titanium_button"
            android:src="@android:drawable/ic_lock_lock"
            android:tint="#FFFFFF"
            android:contentDescription="Security" />

        <!-- BLOCK: Settings Tab -->
        <!-- PURPOSE: Opens ProviderSettingsActivity -->
        <!-- SAFE: comment only -->
        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/titanium_button"
            android:src="@android:drawable/ic_menu_preferences"
            android:tint="#FFFFFF"
            android:contentDescription="Settings" />
    </LinearLayout>

    <!-- BLOCK: Chat Recycler -->
    <!-- PURPOSE: Displays chat bubbles -->
    <!-- SAFE: comment only -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chatRecycler"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="12dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/inputContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- BLOCK: Input Container -->
    <!-- PURPOSE: Holds voice, file, text input, and send button -->
    <!-- SAFE: comment only -->
    <LinearLayout
        android:id="@+id/inputContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- BLOCK: Voice Button -->
        <!-- PURPOSE: Activates voice input -->
        <!-- SAFE: comment only -->
        <ImageButton
            android:id="@+id/btnVoice"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/titanium_button"
            android:src="@android:drawable/ic_btn_speak_now"
            android:tint="#FFFFFF"
            android:contentDescription="Voice" />

        <!-- BLOCK: File Button -->
        <!-- PURPOSE: Opens file picker -->
        <!-- SAFE: comment only -->
        <ImageButton
            android:id="@+id/btnFile"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/titanium_button"
            android:src="@android:drawable/ic_menu_upload"
            android:tint="#FFFFFF"
            android:contentDescription="File" />

        <!-- BLOCK: Input Text -->
        <!-- PURPOSE: User text entry -->
        <!-- SAFE: comment only -->
        <EditText
            android:id="@+id/inputText"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/input_background"
            android:textColor="#FFFFFF"
            android:textColorHint="#888888"
            android:hint="Say something..."
            android:padding="8dp" />

        <!-- BLOCK: Send Button -->
        <!-- PURPOSE: Sends chat message -->
        <!-- SAFE: comment only -->
        <ImageButton
            android:id="@+id/btnSend"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/titanium_button"
            android:src="@android:drawable/ic_menu_send"
            android:tint="#FFFFFF"
            android:contentDescription="Send" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

