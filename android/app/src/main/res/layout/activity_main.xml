<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Face / avatar with titanium ring -->
    <ImageView
        android:id="@+id/faceAvatar"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_margin="12dp"
        android:src="@mipmap/ic_launcher"
        android:scaleType="centerCrop"
        android:background="@drawable/titanium_ring"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Settings button (NEW) -->
    <ImageButton
        android:id="@+id/btnSettings"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_margin="12dp"
        android:background="@drawable/titanium_button"
        android:src="@android:drawable/ic_menu_preferences"
        android:tint="#FFFFFF"
        android:contentDescription="Settings"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Guts panel title -->
    <TextView
        android:id="@id/gutsTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="12dp"
        android:text="Guts"
        android:textColor="#C724B1"
        android:textSize="16sp"
        app:layout_constraintTop_toTopOf="@id/faceAvatar"
        app:layout_constraintStart_toEndOf="@id/faceAvatar"
        app:layout_constraintEnd_toStartOf="@id/btnSettings" />

    <!-- Guts panel -->
    <TextView
        android:id="@+id/gutsPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="4dp"
        android:text="Ready."
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:padding="8dp"
        android:background="@drawable/titanium_border"
        app:layout_constraintTop_toBottomOf="@id/gutsTitle"
        app:layout_constraintStart_toEndOf="@id/faceAvatar"
        app:layout_constraintEnd_toStartOf="@id/btnSettings" />

    <!-- Chat bubbles list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chatRecycler"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="12dp"
        app:layout_constraintTop_toBottomOf="@id/faceAvatar"
        app:layout_constraintBottom_toTopOf="@id/inputContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Input + buttons container -->
    <LinearLayout
        android:id="@+id/inputContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnVoice"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/titanium_button"
            android:src="@android:drawable/ic_btn_speak_now"
            android:tint="#FFFFFF"
            android:contentDescription="Voice" />

        <ImageButton
            android:id="@+id/btnFile"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/titanium_button"
            android:src="@android:drawable/ic_menu_upload"
            android:tint="#FFFFFF"
            android:contentDescription="File" />

        <EditText
            android:id="@+id/inputText"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/input_background"
            android:textColor="#FFFFFF"
            android:textColorHint="#888888"
            android:hint="Say something..."
            android:padding="8dp" />

        <ImageButton
            android:id="@+id/btnSend"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/titanium_button"
            android:src="@android:drawable/ic_menu_send"
            android:tint="#FFFFFF"
            android:contentDescription="Send" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
