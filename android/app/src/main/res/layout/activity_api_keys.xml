<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/apiKeysRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@android:color/background_dark">

    <!-- BLOCK: Scrollable Main Section -->
    <!-- PURPOSE: Holds all provider API key inputs -->
    <!-- SAFE: comment only -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fadeScrollbars="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- BLOCK: OpenAI Section -->
            <!-- PURPOSE: Input for OpenAI API key -->
            <!-- SAFE: comment only -->
            <TextView
                android:id="@+id/openAiLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OpenAI API Key"
                android:textSize="18sp"
                android:textColor="@android:color/white"
                android:paddingBottom="8dp" />

            <EditText
                android:id="@+id/openAiKeyInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/background_dark"
                android:padding="12dp"
                android:textColor="@android:color/white"
                android:hint="Enter OpenAI key" />

            <!-- BLOCK: Anthropic Section -->
            <!-- PURPOSE: Input for Anthropic API key -->
            <!-- SAFE: comment only -->
            <TextView
                android:id="@+id/anthropicLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Anthropic API Key"
                android:textSize="18sp"
                android:textColor="@android:color/white"
                android:paddingTop="24dp"
                android:paddingBottom="8dp" />

            <EditText
                android:id="@+id/anthropicKeyInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/background_dark"
                android:padding="12dp"
                android:textColor="@android:color/white"
                android:hint="Enter Anthropic key" />

            <!-- BLOCK: Gemini Section -->
            <!-- PURPOSE: Input for Gemini API key -->
            <!-- SAFE: comment only -->
            <TextView
                android:id="@+id/geminiLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gemini API Key"
                android:textSize="18sp"
                android:textColor="@android:color/white"
                android:paddingTop="24dp"
                android:paddingBottom="8dp" />

            <EditText
                android:id="@+id/geminiKeyInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/background_dark"
                android:padding="12dp"
                android:textColor="@android:color/white"
                android:hint="Enter Gemini key" />

            <!-- BLOCK: Local Provider Section -->
            <!-- PURPOSE: Input for local provider key -->
            <!-- SAFE: comment only -->
            <TextView
                android:id="@+id/localLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Local Provider Key"
                android:textSize="18sp"
                android:textColor="@android:color/white"
                android:paddingTop="24dp"
                android:paddingBottom="8dp" />

            <EditText
                android:id="@+id/localKeyInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/background_dark"
                android:padding="12dp"
                android:textColor="@android:color/white"
                android:hint="Enter Local provider key" />

            <!-- BLOCK: Save Button -->
            <!-- PURPOSE: Saves encrypted API keys -->
            <!-- SAFE: comment only -->
            <Button
                android:id="@+id/saveApiKeysBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Save API Keys"
                android:textColor="@android:color/white"
                android:background="@android:color/holo_blue_dark"
                android:layout_marginTop="24dp" />

        </LinearLayout>
    </ScrollView>

    <!-- BLOCK: Danger Zone -->
    <!-- PURPOSE: Clear all API keys (irreversible) -->
    <!-- SAFE: comment only -->
    <LinearLayout
        android:id="@+id/apiDangerZone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="16dp">

        <TextView
            android:id="@+id/apiDangerLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Danger Zone"
            android:textSize="18sp"
            android:textColor="@android:color/holo_red_dark"
            android:paddingBottom="8dp" />

        <Button
            android:id="@+id/clearApiKeysBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Clear All API Keys (Irreversible)"
            android:textColor="@android:color/white"
            android:background="@android:color/holo_red_dark" />
    </LinearLayout>

</LinearLayout>

