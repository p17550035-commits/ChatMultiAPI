<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/background_light">

    <LinearLayout
        android:orientation="vertical"
        android:padding="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Provider Section -->
        <TextView
            android:id="@+id/providerLabel"
            android:text="Provider"
            android:textSize="18sp"
            android:textColor="@android:color/black"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <Spinner
            android:id="@+id/providerSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- API Key Section -->
        <TextView
            android:id="@+id/apiKeyLabel"
            android:text="API Key"
            android:textSize="18sp"
            android:textColor="@android:color/black"
            android:paddingTop="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <EditText
            android:id="@+id/keyInput"
            android:hint="Enter API key"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:background="@android:color/white"
            android:textColor="@android:color/black" />

        <!-- Custom URL Section -->
        <TextView
            android:id="@+id/customUrlLabel"
            android:text="Custom URL"
            android:textSize="18sp"
            android:textColor="@android:color/black"
            android:paddingTop="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <EditText
            android:id="@+id/customUrlInput"
            android:hint="Only for custom provider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:background="@android:color/white"
            android:textColor="@android:color/black" />

        <!-- Save + Load Buttons -->
        <Button
            android:id="@+id/btnSave"
            android:text="Save"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:background="@android:color/holo_blue_light"
            android:textColor="@android:color/white" />

        <Button
            android:id="@+id/btnLoad"
            android:text="Load"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@android:color/holo_blue_dark"
            android:textColor="@android:color/white" />

        <!-- Dark Mode Toggle Placeholder -->
        <TextView
            android:id="@+id/darkModeToggleDisabledMsg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dark Mode toggle is disabled until setup is complete.\nIt will unlock automatically after your API responds at least once."
            android:textColor="@android:color/darker_gray"
            android:textSize="14sp"
            android:paddingTop="30dp"
            android:paddingBottom="20dp"
            android:gravity="center" />

    </LinearLayout>
</ScrollView>

