<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/projectsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/neon_background">

    <!-- BLOCK: Header -->
    <!-- PURPOSE: Displays the Projects title in neon theme -->
    <!-- SAFE: comment only, no runtime effect -->
    <TextView
        android:id="@+id/projectsHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Projects"
        android:textSize="24sp"
        android:textColor="@color/neon_accent"
        android:paddingBottom="16dp" />

    <!-- BLOCK: Project List -->
    <!-- PURPOSE: Shows list of projects using ListView -->
    <!-- SAFE: comment only -->
    <ListView
        android:id="@+id/projectListView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@color/neon_accent"
        android:dividerHeight="1dp" />

    <!-- BLOCK: New Project Button -->
    <!-- PURPOSE: Button to create a new project -->
    <!-- SAFE: comment only -->
    <Button
        android:id="@+id/newProjectBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="New Project"
        android:textColor="@android:color/white"
        android:background="@color/neon_accent"
        android:padding="12dp"
        android:layout_marginTop="16dp" />

</LinearLayout>

