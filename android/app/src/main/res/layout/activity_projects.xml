<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/projectsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/neonBackground">

    <!-- Header -->
    <TextView
        android:id="@+id/projectsHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Projects"
        android:textSize="24sp"
        android:textColor="@color/neonAccent"
        android:paddingBottom="16dp" />

    <!-- Project List -->
    <ListView
        android:id="@+id/projectListView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@color/neonAccent"
        android:dividerHeight="1dp" />

    <!-- New Project Button -->
    <Button
        android:id="@+id/newProjectBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="New Project"
        android:textColor="@android:color/white"
        android:background="@color/neonAccent"
        android:padding="12dp"
        android:layout_marginTop="16dp" />

</LinearLayout>
