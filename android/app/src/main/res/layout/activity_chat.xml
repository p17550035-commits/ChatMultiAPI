<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/chatRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neon_background">

    <!-- BLOCK: Dev Toolbar -->
    <!-- PURPOSE: Provider/model selection + upload/share/Bluetooth/push-pull/settings -->
    <!-- SAFE: comment only -->
    <LinearLayout
        android:id="@+id/devToolbar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:padding="6dp"
        android:background="@color/neon_panel">

        <Spinner
            android:id="@+id/providerSpinner"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:padding="4dp"
            android:background="@color/neon_accent"
            android:spinnerMode="dropdown" />

        <Spinner
            android:id="@+id/modelSpinner"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:padding="4dp"
            android:layout_marginLeft="6dp"
            android:background="@color/neon_accent"
            android:spinnerMode="dropdown" />

        <ImageButton
            android:id="@+id/toolbarUploadBtn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginLeft="10dp"
            android:background="@color/neon_accent"
            android:src="@drawable/ic_upload"
            android:contentDescription="Upload" />

        <ImageButton
            android:id="@+id/toolbarShareBtn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginLeft="6dp"
            android:background="@color/neon_accent"
            android:src="@drawable/ic_share"
            android:contentDescription="Share" />

        <ImageButton
            android:id="@+id/toolbarBluetoothBtn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginLeft="6dp"
            android:background="@color/neon_accent"
            android:src="@drawable/ic_bluetooth"
            android:contentDescription="Bluetooth" />

        <ImageButton
            android:id="@+id/toolbarPushPullBtn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginLeft="6dp"
            android:background="@color/neon_accent"
            android:src="@drawable/ic_sync"
            android:contentDescription="Push/Pull" />

        <ImageButton
            android:id="@+id/toolbarSettingsBtn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginLeft="6dp"
            android:background="@color/neon_accent"
            android:src="@drawable/ic_settings"
            android:contentDescription="Settings" />

    </LinearLayout>

    <!-- BLOCK: Upload Strip -->
    <!-- PURPOSE: Horizontal scroll of attached files -->
    <!-- SAFE: comment only -->
    <HorizontalScrollView
        android:id="@+id/uploadStrip"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="48dp"
        android:background="@color/neon_panel"
        android:padding="6dp"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/uploadStripContainer"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal" />
    </HorizontalScrollView>

    <!-- BLOCK: Upload Strip Clear Button -->
    <!-- PURPOSE: Clear all selected files -->
    <!-- SAFE: comment only -->
    <ImageButton
        android:id="@+id/uploadStripClearBtn"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginTop="6dp"
        android:layout_marginLeft="6dp"
        android:layout_gravity="end"
        android:background="@color/neon_accent"
        android:src="@drawable/ic_close"
        android:contentDescription="Clear Upload Strip"
        android:visibility="gone" />

    <!-- BLOCK: Chat Recycler -->
    <!-- PURPOSE: Displays chat bubbles -->
    <!-- SAFE: comment only -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chatRecycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="108dp"
        android:layout_marginBottom="70dp"
        android:padding="8dp"
        android:background="@color/neon_background" />

    <!-- BLOCK: Input Bar -->
    <!-- PURPOSE: Chat input + attach + send -->
    <!-- SAFE: comment only -->
    <LinearLayout
        android:id="@+id/chatInputRow"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="@color/neon_panel">

        <EditText
            android:id="@+id/chatInput"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:hint="Type a message..."
            android:padding="10dp"
            android:background="@color/neon_panel_dark"
            android:textColor="@android:color/white"
            android:textSize="16sp" />

        <ImageButton
            android:id="@+id/chatAttach"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginLeft="8dp"
            android:background="@color/neon_accent"
            android:src="@drawable/ic_attach"
            android:contentDescription="Attach" />

        <ImageButton
            android:id="@+id/chatSend"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginLeft="8dp"
            android:background="@color/neon_accent"
            android:src="@drawable/ic_send"
            android:contentDescription="Send" />
    </LinearLayout>

    <!-- BLOCK: Mini Terminal -->
    <!-- PURPOSE: Slide-up terminal overlay for logs + commands -->
    <!-- SAFE: comment only -->
    <LinearLayout
        android:id="@+id/miniTerminalPanel"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@color/neon_panel_dark"
        android:padding="8dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/miniTerminalTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mini Terminal"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:padding="6dp" />

        <ScrollView
            android:id="@+id/miniTerminalScroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <TextView
                android:id="@+id/miniTerminalOutput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:padding="6dp" />
        </ScrollView>

        <EditText
            android:id="@+id/miniTerminalInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter command..."
            android:padding="10dp"
            android:background="@color/neon_panel"
            android:textColor="@android:color/white" />

        <Button
            android:id="@+id/miniTerminalRunBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Run Command"
            android:background="@color/neon_accent"
            android:textColor="@android:color/white"
            android:padding="10dp"
            android:layout_marginTop="6dp" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>

