<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/chatRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neonBackground">

    <!-- ========================================================= -->
    <!-- DEV TOOLBAR (Provider, Model, Upload, Share, Bluetooth)   -->
    <!-- ========================================================= -->
    <LinearLayout
        android:id="@+id/devToolbar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:padding="6dp"
        android:background="@color/neonPanel">

        <Spinner
            android:id="@+id/providerSpinner"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:padding="4dp"
            android:background="@color/neonAccent"
            android:spinnerMode="dropdown" />

        <Spinner
            android:id="@+id/modelSpinner"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:padding="4dp"
            android:layout_marginLeft="6dp"
            android:background="@color/neonAccent"
            android:spinnerMode="dropdown" />

        <ImageButton
            android:id="@+id/toolbarUploadBtn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginLeft="10dp"
            android:background="@color/neonAccent"
            android:src="@drawable/ic_upload"
            android:contentDescription="Upload" />

        <ImageButton
            android:id="@+id/toolbarShareBtn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginLeft="6dp"
            android:background="@color/neonAccent"
            android:src="@drawable/ic_share"
            android:contentDescription="Share" />

        <ImageButton
            android:id="@+id/toolbarBluetoothBtn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginLeft="6dp"
            android:background="@color/neonAccent"
            android:src="@drawable/ic_bluetooth"
            android:contentDescription="Bluetooth" />

        <ImageButton
            android:id="@+id/toolbarPushPullBtn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginLeft="6dp"
            android:background="@color/neonAccent"
            android:src="@drawable/ic_sync"
            android:contentDescription="Push/Pull" />

        <ImageButton
            android:id="@+id/toolbarSettingsBtn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginLeft="6dp"
            android:background="@color/neonAccent"
            android:src="@drawable/ic_settings"
            android:contentDescription="Settings" />

    </LinearLayout>

    <!-- ========================================================= -->
    <!-- HORIZONTAL UPLOAD STRIP                                   -->
    <!-- ========================================================= -->
    <HorizontalScrollView
        android:id="@+id/uploadStrip"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="48dp"
        android:background="@color/neonPanel"
        android:padding="6dp"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/uploadStripContainer"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal" />
    </HorizontalScrollView>

    <!-- ========================================================= -->
    <!-- CHAT RECYCLER VIEW                                        -->
    <!-- ========================================================= -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chatRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="108dp"
        android:layout_marginBottom="70dp"
        android:padding="8dp"
        android:background="@color/neonBackground" />

    <!-- ========================================================= -->
    <!-- INPUT BAR                                                  -->
    <!-- ========================================================= -->
    <LinearLayout
        android:id="@+id/chatInputRow"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="@color/neonPanel">

        <EditText
            android:id="@+id/chatInput"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:hint="Type a message..."
            android:padding="10dp"
            android:background="@color/neonPanelDark"
            android:textColor="@android:color/white"
            android:textSize="16sp" />

        <ImageButton
            android:id="@+id/attachBtn"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginLeft="8dp"
            android:background="@color/neonAccent"
            android:src="@drawable/ic_attach"
            android:contentDescription="Attach" />

        <ImageButton
            android:id="@+id/sendBtn"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginLeft="8dp"
            android:background="@color/neonAccent"
            android:src="@drawable/ic_send"
            android:contentDescription="Send" />
    </LinearLayout>

    <!-- ========================================================= -->
    <!-- MINI TERMINAL OVERLAY                                     -->
    <!-- ========================================================= -->
    <LinearLayout
        android:id="@+id/miniTerminalPanel"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@color/neonPanelDark"
        android:padding="8dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/miniTerminalTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mini Terminal"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:padding="6dp" />

        <ScrollView
            android:id="@+id/miniTerminalScroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <TextView
                android:id="@+id/miniTerminalOutput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:padding="6dp" />
        </ScrollView>

        <EditText
            android:id="@+id/miniTerminalInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter command..."
            android:padding="10dp"
            android:background="@color/neonPanel"
            android:textColor="@android:color/white" />

        <Button
            android:id="@+id/miniTerminalRunBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Run Command"
            android:background="@color/neonAccent"
            android:textColor="@android:color/white"
            android:padding="10dp"
            android:layout_marginTop="6dp" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>

